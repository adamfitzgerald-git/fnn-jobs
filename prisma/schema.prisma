generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  JOBSEEKER
  EMPLOYER_ADMIN
  SUPER_ADMIN
}

enum RapTier {
  NONE
  REFLECT
  INNOVATE
  STRETCH
  ELEVATE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  CASUAL
}

enum WorkMode {
  REMOTE
  HYBRID
  ON_SITE
}

enum ListingStatus {
  PUBLISHED
  DRAFT
  CLOSED
}

enum EmployerStatus {
  PUBLISHED
  DRAFT
}

enum ApplyMethod {
  EMAIL
  URL
}

enum MaturityDimensionType {
  EMPLOYMENT
  LEADERSHIP
  CULTURAL_SAFETY
  SUPPLIER_DIVERSITY
  COMMUNITY_ENGAGEMENT
  RAP_ACCOUNTABILITY
  MEASUREMENT
}

enum TargetMetStatus {
  MET
  PARTIALLY_MET
  NOT_MET
  IN_PROGRESS
}

enum PledgeStatus {
  ACTIVE
  ACHIEVED
  OVERDUE
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  hashedPassword String
  role           UserRole  @default(JOBSEEKER)
  bio            String?
  location       String?
  emailNotifications Boolean @default(false)
  employerId     String?
  employer       Employer? @relation(fields: [employerId], references: [id])
  savedJobs      SavedJob[]
  expressionsOfInterest ExpressionOfInterest[]
  alertPreference AlertPreference?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Employer {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  logo            String?
  sector          String
  headquarters    String?
  websiteUrl      String?
  shortDescription String?
  fullDescription String?        @db.Text
  rapTier         RapTier        @default(NONE)
  videoUrl        String?
  photoGallery    String[]
  linkedinUrl     String?
  facebookUrl     String?
  instagramUrl    String?
  xUrl            String?
  contactName     String?
  contactEmail    String?
  status          EmployerStatus @default(DRAFT)
  groVerified     Boolean        @default(false)
  ibmPartner      Boolean        @default(false)
  spotlightUrl    String?
  spotlightTitle  String?
  jobs            Job[]
  admins          User[]
  expressionsOfInterest ExpressionOfInterest[]
  maturityDimensions MaturityDimension[]
  rapProgress     RapProgress[]
  commitmentPledges CommitmentPledge[]
  events          Event[]
  pageViews       PageView[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Job {
  id              String         @id @default(cuid())
  title           String
  slug            String         @unique
  employerId      String
  employer        Employer       @relation(fields: [employerId], references: [id], onDelete: Cascade)
  location        String
  workMode        WorkMode       @default(ON_SITE)
  employmentType  EmploymentType @default(FULL_TIME)
  salaryRange     String?
  identifiedRole  Boolean        @default(false)
  description     String         @db.Text
  applyMethod     ApplyMethod    @default(EMAIL)
  applyValue      String
  closingDate     DateTime?
  featured        Boolean        @default(false)
  status          ListingStatus  @default(DRAFT)
  savedBy         SavedJob[]
  expressionsOfInterest ExpressionOfInterest[]
  pageViews       PageView[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
}

model ExpressionOfInterest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employerId  String
  employer    Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
  jobId       String?
  job         Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  message     String   @db.Text
  createdAt   DateTime @default(now())
}

model MaturityDimension {
  id          String                @id @default(cuid())
  employerId  String
  employer    Employer              @relation(fields: [employerId], references: [id], onDelete: Cascade)
  dimension   MaturityDimensionType
  summary     String?               @db.Text
  initiatives String?               @db.Text
  evidence    String?               @db.Text
  status      String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([employerId, dimension])
}

model RapProgress {
  id             String          @id @default(cuid())
  employerId     String
  employer       Employer        @relation(fields: [employerId], references: [id], onDelete: Cascade)
  year           Int
  targetSet      String?         @db.Text
  achieved       String?         @db.Text
  initiatives    String?         @db.Text
  targetMet      TargetMetStatus @default(IN_PROGRESS)
  externalLink   String?
  nextYearTarget String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([employerId, year])
}

model CommitmentPledge {
  id             String       @id @default(cuid())
  employerId     String
  employer       Employer     @relation(fields: [employerId], references: [id], onDelete: Cascade)
  text           String       @db.Text
  dueDate        DateTime
  status         PledgeStatus @default(ACTIVE)
  reminderSentAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Event {
  id              String   @id @default(cuid())
  employerId      String
  employer        Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
  title           String
  description     String?  @db.Text
  date            DateTime
  registrationUrl String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SalaryBenchmark {
  id        String @id @default(cuid())
  sector    String
  location  String
  medianMin Int
  medianMax Int
}

model PageView {
  id         String    @id @default(cuid())
  employerId String?
  employer   Employer? @relation(fields: [employerId], references: [id], onDelete: Cascade)
  jobId      String?
  job        Job?      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  viewedAt   DateTime  @default(now())
}

model AlertPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sectors   String[]
  locations String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
